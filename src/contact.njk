---
layout: base.njk
title: Contact
description: "Inquire with Amore Coordination — Portland, Oregon wedding planning by Amy Elizabeth Ha. Call (503) 502-9231 or send a note about your celebration."
---

<section class="contact contact--page">
  <div class="contact__inner">
    <p class="section__eyebrow">Let's Connect</p>
    <h1 class="page-hero__title">Inquire</h1>
    <p class="contact__lead">
      Tell me a little about your day. This information is for planning purposes only and
      will always remain confidential.
    </p>

    <form class="contact__form" name="inquiry" method="POST" data-netlify="true" netlify-honeypot="bot-field" action="/thank-you/">
      <input type="hidden" name="form-name" value="inquiry" />
      <p class="hidden-field"><label>Don't fill this out: <input name="bot-field" /></label></p>
      <div class="field">
        <input type="text" name="Name" placeholder="Your name(s)" required />
      </div>
      <div class="field-row">
        <div class="field"><input type="email" name="Email" placeholder="Email" required /></div>
        <div class="field"><input type="tel" name="Phone" placeholder="Phone" /></div>
      </div>
      <div class="field-row">
        <div class="field"><input type="text" name="Wedding Date" placeholder="Wedding / event date" /></div>
        <div class="field"><input type="text" name="Venue" placeholder="Venue (if known)" /></div>
      </div>
      <div class="field">
        <textarea name="Message" rows="5" placeholder="Tell me about your vision…"></textarea>
      </div>
      <button type="submit" class="btn btn--dark">Send Inquiry</button>
    </form>

    <div class="contact__details">
      <a href="mailto:{{ site.email }}">{{ site.email }}</a>
      <a href="tel:{{ site.phoneRaw }}">{{ site.phone }}</a>
    </div>
  </div>
</section>
